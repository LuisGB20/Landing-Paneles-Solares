---
const projects = [
	{
		title: "Hotel Boutique Riviera",
		location: "Cancún, Quintana Roo",
		description:
			"Instalación de un sistema fotovoltaico para reducir el consumo eléctrico y mejorar la eficiencia energética del hotel.",
		image: "images/projects/project-1.jpg",
		type: "Hotelero",
	},
	{
		title: "Residencial Aqua",
		location: "Cancún, Quintana Roo",
		description:
			"Sistema residencial diseñado para disminuir el costo del recibo de luz y aprovechar la energía solar durante todo el año.",
		image: "images/projects/project-5.jpg",
		type: "Residencial",
	},
	{
		title: "Restaurante La Isla",
		location: "Zona Hotelera, Cancún",
		description:
			"Proyecto comercial enfocado en reducir los gastos operativos mediante energía limpia y renovable.",
		image: "images/projects/project-3.jpg",
		type: "Comercial",
	},
	{
		title: "Condominios Mar Azul",
		location: "Puerto Morelos",
		description:
			"Implementación de paneles solares para las áreas comunes del complejo, logrando un importante ahorro energético.",
		image: "images/projects/project-4.jpg",
		type: "Residencial",
	},
	{
		title: "Centro Logístico Caribe",
		location: "Cancún, Quintana Roo",
		description:
			"Solución fotovoltaica para optimizar el consumo eléctrico de las operaciones industriales y administrativas.",
		image: "images/projects/project-2.jpg",
		type: "Industrial",
	},
];
---

<section id="proyectos" class="py-10 overflow-hidden">
	<div class="mx-auto w-full px-10">
		<div
			class="mb-14 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between"
		>
			<div class="text-center lg:text-start">
				<h2 class="mt-5 text-3xl font-bold text-primary md:text-5xl">
					Proyectos que generan resultados
				</h2>

				<p class="mt-5 max-w-2xl text-secondary">
					Descubre algunos de los sistemas fotovoltaicos que hemos
					instalado para hogares, comercios y empresas de la Riviera
					Maya.
				</p>
			</div>
		</div>
	</div>

	<div
		class="flex gap-8 overflow-x-auto px-6 pb-4 scrollbar-hide snap-x snap-mandatory"
	>
		{
			projects.map((project) => (
				<article class="group min-w-[350px] max-w-[350px] lg:min-w-[700px] lg:max-w-[700px] snap-start overflow-hidden rounded-3xl bg-primary">
					<div class="relative h-80 overflow-hidden">
						<img
							src={project.image}
							alt={project.title}
							class="h-full w-full object-cover transition duration-700 group-hover:scale-110"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent" />
						<span class="absolute left-5 top-5 rounded-full bg-primary px-4 py-2 text-xs font-bold uppercase text-baseLight">
							{project.type}
						</span>
					</div>

					<div class="p-6">
						<h3 class="text-2xl font-bold text-baseLight">{project.title}</h3>
						<p class="mt-2 text-baseLight">{project.location}</p>
						<p class="mt-4 text-baseLight">{project.description}</p>
					</div>
				</article>
			))
		}
	</div>
</section>

<style>
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}

	.scrollbar-hide {
		scrollbar-width: none;
	}
</style>
