---
import { Image } from 'astro:assets';
import Logo from '../assets/logo.png';
---

<header x-data="{ open: false }" class="relative">
  <div class="mx-auto flex w-full items-center justify-between px-4 py-4 md:px-10">

    <a href="#" class="flex items-center text-2xl font-bold text-primary">
      <Image src={Logo} alt="Logo" class="mr-2 size-8" />
      <h3 class="text-3xl font-extrabold text-primary">SolNativa</h3>
    </a>

    <!-- Navegación escritorio -->
    <nav class="hidden items-center gap-8 font-medium lg:flex">
      <a href="/" class="text-secondary transition hover:text-primary">Inicio</a>
      <a href="#servicios" class="text-secondary transition hover:text-primary">Servicios</a>
      <a href="#proyectos" class="text-secondary transition hover:text-primary">Proyectos</a>
      <a href="#nosotros" class="text-secondary transition hover:text-primary">Nosotros</a>
    </nav>

    <a href="#" class="hidden rounded-2xl bg-accent px-4 py-3 font-semibold text-baseLight transition hover:bg-primary duration-150 ease-in-out lg:block">
      Solicitar cotización
    </a>

    <!-- Botón menú móvil -->
    <button @click="open = !open" class="lg:hidden">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Menú desplegable móvil -->
  <nav 
    x-cloak
    x-show="open" 
    @click.outside="open = false"
    class="absolute z-50 left-0 top-full w-full flex-col gap-4 bg-white p-6 shadow-xl lg:hidden flex"
  >
    <a href="/" class="text-secondary hover:text-primary">Inicio</a>
    <a href="#servicios" class="text-secondary hover:text-primary">Servicios</a>
    <a href="#proyectos" class="text-secondary hover:text-primary">Proyectos</a>
    <a href="#nosotros" class="text-secondary hover:text-primary">Nosotros</a>
    <a href="#" class="mt-2 rounded-2xl bg-accent px-4 py-3 text-center font-semibold text-baseLight">
      Solicitar cotización
    </a>
  </nav>
</header>