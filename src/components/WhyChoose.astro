---
import { Image } from "astro:assets";
import WhyChooseImage from "../assets/panel.webp";

const faqs = [
	{
		question: "¿Realmente puedo ahorrar en mi recibo de luz?",
		answer: "Sí. Un sistema fotovoltaico bien dimensionado puede reducir entre un 70% y un 95% el consumo de energía proveniente de la red eléctrica, dependiendo de tus hábitos de consumo.",
	},
	{
		question: "¿Cuánto dura un sistema de paneles solares?",
		answer: "Los paneles solares tienen una vida útil superior a 25 años. Además, los inversores y demás componentes cuentan con garantías que van de 5 a 15 años según el fabricante.",
	},
	{
		question: "¿Funcionan los paneles cuando está nublado?",
		answer: "Sí. Los paneles siguen generando energía incluso en días nublados, aunque con una producción menor. Cancún cuenta con un excelente nivel de radiación solar durante la mayor parte del año.",
	},
	{
		question: "¿La instalación requiere mucho mantenimiento?",
		answer: "No. Únicamente se recomienda realizar limpiezas periódicas e inspecciones preventivas para mantener el máximo rendimiento del sistema.",
	},
	{
		question: "¿En cuánto tiempo recupero mi inversión?",
		answer: "Generalmente entre 3 y 6 años, dependiendo del consumo eléctrico, la tarifa de CFE y el tamaño del sistema instalado.",
	},
];
---

<section id="por-que-elegirnos" class="py-10">
	<div class="mx-auto w-full px-10">
		<div class="mx-auto mb-14 max-w-3xl text-center">
			<h2 class="mt-5 text-4xl font-bold text-primary md:text-5xl">
				¿Por qué elegir energía solar?
			</h2>

			<p class="mt-5 text-lg text-secondary">
				Descubre por qué miles de hogares y empresas están apostando por
				una fuente de energía limpia, rentable y sostenible.
			</p>
		</div>

		<div class="flex flex-col lg:flex-row justify-between space-x-20">
			<div class="w-1/2 lg:w-1/3 m-auto">
				<Image
					src={WhyChooseImage}
					alt="Why choose solar energy"
					class={"m-auto"}
				/>
			</div>
			<div class="mx-auto w-full lg:w-2/3 space-y-5 mt-5 lg:mt-0">
				{
					faqs.map((faq, index) => (
						<article class="overflow-hidden rounded-2xl border border-slate-200 bg-baseLight shadow-sm">
							<button
								class="faq-btn flex w-full items-center justify-between px-6 py-5 text-left"
								data-index={index}
							>
								<span class="text-base lg:text-lg font-semibold text-secondary">
									{faq.question}
								</span>

								<span class="icon flex h-10 w-10 items-center justify-center rounded-full bg-primary text-xl font-bold text-baseLight transition-transform duration-300">
									+
								</span>
							</button>

							<div class="faq-content text-sm lg:text-base hidden border-t border-slate-100 px-6 py-5 text-slate-600">
								{faq.answer}
							</div>
						</article>
					))
				}
			</div>
		</div>
	</div>
</section>

<script>
	const buttons = document.querySelectorAll(".faq-btn");

	buttons.forEach((button) => {
		button.addEventListener("click", () => {
			const content = button.nextElementSibling;
			const icon = button.querySelector(".icon");

			// Cerrar los demás
			document.querySelectorAll(".faq-content").forEach((item) => {
				if (item !== content) item.classList.add("hidden");
			});

			document.querySelectorAll(".icon").forEach((item) => {
				if (item !== icon) {
					item.textContent = "+";
					item.classList.remove("rotate-90");
				}
			});

			if (content == null) return;
			if (icon == null) return;

			// Toggle actual
			content.classList.toggle("hidden");

			if (content.classList.contains("hidden")) {
				icon.textContent = "+";
				icon.classList.remove("rotate-90");
			} else {
				icon.textContent = "×";
				icon.classList.add("rotate-90");
			}
		});
	});
</script>
