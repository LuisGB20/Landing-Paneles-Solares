---
import { Image } from "astro:assets";
import About2 from "../../public/images/about/about-2.webp";
import About3 from "../../public/images/about/about-3.webp";
import About4 from "../../public/images/about/about-4.webp";
---

<section id="nosotros" class="w-full py-5 md:py-10">
	<div class="mx-auto w-full px-10">
		<div class="grid items-center gap-10 lg:gap-16 lg:grid-cols-2">
			<div>
				<h2
					class="mt-6 text-2xl md:text-3xl lg:text-5xl text-start font-extrabold leading-tight text-secondary"
				>
					Transformamos la luz del sol en <span class="text-primary"
						>ahorro y sostenibilidad.</span
					>
				</h2>

				<p class="mt-6 text-base lg:text-lg text-start leading-relaxed text-gray-600">
					En <strong>SolNativa Energy</strong> desarrollamos soluciones
					de energía solar para hogares, comercios y empresas de Cancún
					y la Riviera Maya. Nuestro objetivo es ayudar a nuestros clientes
					a disminuir sus costos de electricidad mediante tecnología confiable,
					instalaciones certificadas y un servicio cercano.
				</p>

				<p class="mt-4 text-start text-base lg:text-lg leading-relaxed text-gray-600">
					Cada proyecto es diseñado a la medida, garantizando el
					máximo rendimiento, seguridad y una inversión inteligente
					para el futuro.
				</p>

				<div class="mt-10 flex flex-col md:flex-row text-center items-center justify-center lg:justify-start gap-4">
					<a
						href="#por-que-elegirnos"
						class="rounded-2xl w-full md:w-auto border-2 border-secondary bg-secondary px-4 lg:px-8 py-3 text-sm lg:text-base font-semibold text-white transition hover:bg-primary hover:border-primary"
					>
						Conocer más
					</a>

					<a
						href="#proyectos"
						class="rounded-2xl w-full md:w-auto border-2 border-primary px-4 lg:px-8 py-3 text-sm lg:text-base font-semibold text-primary transition hover:bg-secondary hover:text-white hover:border-secondary"
					>
						Nuestros proyectos
					</a>
				</div>
			</div>

			<div class="relative space-y-5">
				<div class="grid grid-cols-2 gap-5">
					<Image
						src={About4}
						alt="Proyecto de energía solar en Cancún"
						class="col-span-2 h-60 w-full rounded-3xl object-cover shadow-lg"
					/>

					<Image
						src={About2}
						alt="Instalación de paneles solares en un hogar"
						class="h-52 hidden lg:block w-full rounded-3xl object-cover shadow-lg"
					/>

					<Image
						src={About3}
						alt="Cliente satisfecho con el sistema de energía solar"
						class="h-52 hidden lg:block w-full rounded-3xl object-cover shadow-lg"
					/>
				</div>

				<!-- Estadísticas -->
				<div class="-bottom-8 right-6">
					<div
						class="grid lg:grid-cols-3 overflow-hidden rounded-2xl bg-primary text-baseLight shadow-2xl"
					>
						<div class="px-8 py-6 text-center border-b-2 lg:border-b-0 lg:border-r-2 border-baseLight">
							<h3 class="text-2xl lg:text-4xl font-bold text-accent">12+</h3>

							<p class="mt-2 text-sm text-baseLight">
								Años de experiencia
							</p>
						</div>

						<div class="px-8 py-6 text-center border-b-2 lg:border-b-0 lg:border-r-2 border-baseLight">
							<h3 class="text-2xl lg:text-4xl font-bold text-accent">600+</h3>

							<p class="mt-2 text-sm text-baseLight">
								Sistemas instalados
							</p>
						</div>

						<div class="px-8 py-6 text-center border-b-2 lg:border-b-0 lg:border-r-2 border-baseLight">
							<h3 class="text-2xl lg:text-4xl font-bold text-accent">98%</h3>

							<p class="mt-2 text-sm text-baseLight">
								Clientes satisfechos
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
